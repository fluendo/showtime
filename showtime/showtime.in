import gettext
import locale
import signal
import sys
from pathlib import Path
from platform import system

pkgdatadir = "@pkgdatadir@"
localedir = "@localedir@"

# Fix: Add Python modules directory to path
sys.path.insert(1, "@pythondir@")

signal.signal(signal.SIGINT, signal.SIG_DFL)

if system() == "Linux":
    locale.bindtextdomain("@BIN_NAME@", localedir)
    locale.textdomain("@BIN_NAME@")
    gettext.install("@BIN_NAME@", localedir)
else:
    gettext.install("@BIN_NAME@")

if __name__ == "__main__":
    import gi

    gi.require_version("Gtk", "4.0")

    from gi.repository import Gio, GLib, Gtk

    GLib.set_prgname("@BIN_NAME@")
    GLib.set_application_name(_("Video Player"))
    Gtk.Window.set_default_icon_name("@APP_ID@")

    Gio.resources_register(
        Gio.Resource.load(str(Path(pkgdatadir, "showtime.gresource")))
    )

    from showtime import main

    sys.exit(main.main())